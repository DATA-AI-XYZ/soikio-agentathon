# Copy to .env and fill in. NEVER commit .env. This template holds placeholders only.

# --- Agent reasoning model: Claude (your Anthropic key) ---
ANTHROPIC_API_KEY=sk-ant-...                   # the four agents (Bull/Bear/Caution/CIO) run on Claude
CLAUDE_MODEL=claude-sonnet-4-6                  # use Opus for the CIO if you want deeper adjudication
# Alternative: deploy Claude *in* Microsoft Foundry instead of the Anthropic API.
# Then leave ANTHROPIC_API_KEY blank and set the Foundry Claude deployment name here:
# FOUNDRY_CLAUDE_DEPLOYMENT=claude-sonnet-4-6

# --- Microsoft Foundry project ---
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-name>

# --- Azure AI Search (powers Foundry IQ) — Basic tier or higher (agentic retrieval needs the semantic ranker) ---
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KNOWLEDGE_BASE=REDACTED-kb

# --- Azure OpenAI (small model) — ONLY the Foundry IQ query planner, NOT the agents ---
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com
AZURE_OPENAI_PLANNER_DEPLOYMENT=gpt-4o-mini    # tiny: plans retrieval sub-queries only

# --- Knowledge source (public docs) ---
AZURE_STORAGE_ACCOUNT=<your-storage-account>
AZURE_STORAGE_CONTAINER=public-docs

# --- Auth ---
# Azure: prefer managed identity / az login (DefaultAzureCredential).
# Anthropic: ANTHROPIC_API_KEY above (keep it out of git — it lives in .env, which is git-ignored).
AZURE_TENANT_ID=<tenant-guid>

# --- Run options ---
RETRIEVAL_REASONING_EFFORT=low                 # minimal | low | medium
