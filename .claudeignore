# Sensible defaults for Claude Code exclusions
# Per the blog's "Use `.` files to exclude generated code, build artifacts, third-party dependencies"
# Customize per project — see _00-Project-Management/90-Standards/PROJECT-CONTEXT.md "Claude Code exclusions" section.

# Dependencies
node_modules/
.venv/
venv/
vendor/
.pnp/
.pnp.*

# Python build / cache
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
.parcel-cache/

# Test coverage and reports
coverage/
.coverage
.nyc_output/
test-results/
playwright-report/

# Caches
.cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS metadata
.DS_Store
Thumbs.db
*.swp
*.swo

# Secrets — never paste into chat or grep across
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
secrets/

# Generated PM artefacts (markdown is authoritative; HTML is derived)
_00-Project-Management/42-Monitor/DASHBOARD.html
_00-Project-Management/90-Standards/DAILY-WORKFLOW.html
