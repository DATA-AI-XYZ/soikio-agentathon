{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(npm publish*)",
      "Write(.env*)",
      "Write(node_modules/**)",
      "Edit(.env*)",
      "Edit(node_modules/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/_00-Project-Management/93-Scripts/hook.js\" post-tool-use"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/_00-Project-Management/93-Scripts/hook.js\" user-prompt-submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/_00-Project-Management/93-Scripts/hook.js\" stop"
          }
        ]
      }
    ]
  }
}
